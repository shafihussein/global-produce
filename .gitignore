# --- Dependencies ---
# Ignores all node_modules in root, client, server, and database
node_modules/
.npm/

# --- Environment & Secrets ---
# Protects your API keys and secrets
.env
.env.local
.env.*.local
#personal config file
.shafihussein/

# --- IDE & Editor ---
# As requested: ignores VS Code settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Build Outputs ---
# Ignores Vite/React build artifacts
dist/
dist-ssr/
*.local

# --- Test Files ---
# Do not track test or story files in this repository
*.test.js
*.test.ts
*.test.tsx
*.spec.js
*.spec.ts
*.spec.tsx
*.stories.js
*.stories.ts
*.stories.tsx

# --- HTTPS & Security ---
# Protects your OpenSSL certificates and keys
*.key
*.cert
*.pem
*.p12

# --- Database / Persistence ---
# If you want to keep your "source of truth" clean of temp files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
database/output/
database/users/Admin/
database/users/Customers/
server/models/admin-try.js
server/models/customer-try.js

# --- OS Junk ---
.DS_Store
Thumbs.db